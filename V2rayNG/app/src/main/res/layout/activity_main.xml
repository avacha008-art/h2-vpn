<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />

        </com.google.android.material.appbar.AppBarLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.coordinatorlayout.widget.CoordinatorLayout
                android:id="@+id/main_content"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        android:visibility="invisible"
                        app:indicatorColor="@color/color_fab_active" />

                    <com.google.android.material.tabs.TabLayout
                        android:id="@+id/tab_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:tabIndicatorFullWidth="false"
                        app:tabMode="scrollable"
                        app:tabTextAppearance="@style/TabLayoutTextStyle" />

                    <LinearLayout
                        android:id="@+id/stats_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#0A0E1A"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- STATUS CARD -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/card_bg"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <!-- Status row: dot + label -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:id="@+id/pulse_dot"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/pulse_dot" />

                                <TextView
                                    android:id="@+id/tv_status_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="ПОДКЛЮЧЕНО"
                                    android:textColor="#00E5A0"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.14"
                                    android:fontFamily="monospace" />
                            </LinearLayout>

                            <!-- Server info -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="46dp"
                                    android:layout_height="46dp"
                                    android:background="@drawable/flag_bg"
                                    android:gravity="center"
                                    android:text="🇩🇪"
                                    android:textSize="24sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_server_name"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Германия"
                                        android:textColor="#FFFFFF"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tv_server_addr"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:text="45.38.190.244 : 2443 · VLESS"
                                        android:textColor="#8993A4"
                                        android:textSize="11sp"
                                        android:fontFamily="monospace" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Uptime -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:layout_marginBottom="16dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="В СЕТИ"
                                    android:textColor="#5A6377"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.14" />

                                <TextView
                                    android:id="@+id/tv_stats_time"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#1F2738" />

                            <!-- Disconnect button -->
                            <Button
                                android:id="@+id/btn_disconnect"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="14dp"
                                android:backgroundTint="#EB5757"
                                android:text="ОТКЛЮЧИТЬСЯ"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:insetTop="0dp"
                                android:insetBottom="0dp" />

                        </LinearLayout>

                        <!-- STAT CARDS GRID -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <!-- Upload card -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="5dp"
                                android:background="@drawable/stat_card_bg"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="↑ ОТПРАВЛЕНО"
                                    android:textColor="#4ECDC4"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1" />

                                <TextView
                                    android:id="@+id/tv_upload_total"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="0 Б"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:fontFamily="monospace" />

                                <TextView
                                    android:id="@+id/tv_upload_speed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="0 Б/с"
                                    android:textColor="#8993A4"
                                    android:textSize="12sp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>

                            <!-- Download card -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/stat_card_bg"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="↓ ПОЛУЧЕНО"
                                    android:textColor="#6EE7DF"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.1" />

                                <TextView
                                    android:id="@+id/tv_download_total"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="0 Б"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:fontFamily="monospace" />

                                <TextView
                                    android:id="@+id/tv_download_speed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="0 Б/с"
                                    android:textColor="#8993A4"
                                    android:textSize="12sp"
                                    android:fontFamily="monospace" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- PING + SPEED ROW -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/ping_row_bg"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PING  "
                                android:textColor="#5A6377"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_ping_val"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="20dp"
                                android:text="│"
                                android:textColor="#1F2738"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="20dp"
                                android:text="СКОРОСТЬ  "
                                android:textColor="#5A6377"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_speed_val"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <!-- TEST BUTTON -->
                        <Button
                            android:id="@+id/btn_speedtest"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="10dp"
                            android:backgroundTint="#2A6D68"
                            android:text="ТЕСТ СКОРОСТИ"
                            android:textColor="#6EE7DF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                    </LinearLayout>


                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/view_pager"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:nextFocusRight="@+id/fab"
                        android:scrollbars="vertical"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:id="@+id/layout_test"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/view_height_dp64"
                        android:clickable="true"
                        android:contentDescription="@string/connection_test_pending"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/view_pager"
                        android:nextFocusRight="@+id/fab"
                        android:orientation="vertical">

                        <View
                            android:layout_width="wrap_content"
                            android:layout_height="1dp"
                            android:background="@color/divider_color_light" />

                        <TextView
                            android:id="@+id/tv_test_state"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="start|center"
                            android:maxLines="2"
                            android:minLines="1"
                            android:paddingStart="@dimen/padding_spacing_dp16"
                            android:text="@string/connection_test_pending"
                            android:textAppearance="@style/TextAppearance.AppCompat.Small" />

                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginBottom="-16dp"
                    android:layout_marginEnd="@dimen/padding_spacing_dp16">

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fab"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="@dimen/view_height_dp36"
                        android:clickable="true"
                        android:contentDescription="@string/tasker_start_service"
                        android:focusable="true"
                        android:nextFocusLeft="@+id/layout_test"
                        android:src="@drawable/ic_play_24dp"
                        app:tint="@color/colorWhite"
                        app:useCompatPadding="true"
                        app:layout_anchorGravity="bottom|right|end" />

                </FrameLayout>
            </androidx.coordinatorlayout.widget.CoordinatorLayout>
        </RelativeLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_drawer">

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>
