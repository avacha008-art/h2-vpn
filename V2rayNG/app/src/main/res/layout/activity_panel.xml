<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tab_server" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:padding="12dp" android:text="Сервер" android:textColor="#4ECDC4" android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@+id/tab_h2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:padding="12dp" android:text="H2+" android:textColor="#5A6377" android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@+id/tab_log" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:padding="12dp" android:text="Журнал" android:textColor="#5A6377" android:textSize="14sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="2dp">
        <View android:id="@+id/indicator_server" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#4ECDC4" />
        <View android:id="@+id/indicator_h2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1F2738" />
        <View android:id="@+id/indicator_log" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#1F2738" />
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TAB 1: SERVER -->
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <View android:id="@+id/server_dot" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/pulse_dot" />
                        <TextView android:id="@+id/tv_server_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textColor="#00E5A0" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.05" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView android:id="@+id/tv_uptime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#8993A4" android:textSize="11sp" android:fontFamily="monospace" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="42dp" android:layout_height="wrap_content" android:text="CPU" android:textColor="#8993A4" android:textSize="11sp" android:textStyle="bold" />
                        <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:background="@drawable/bar_bg">
                            <View android:id="@+id/bar_cpu" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/bar_cpu" />
                        </FrameLayout>
                        <TextView android:id="@+id/tv_cpu" android:layout_width="40dp" android:layout_height="wrap_content" android:gravity="end" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="42dp" android:layout_height="wrap_content" android:text="RAM" android:textColor="#8993A4" android:textSize="11sp" android:textStyle="bold" />
                        <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:background="@drawable/bar_bg">
                            <View android:id="@+id/bar_ram" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/bar_ram" />
                        </FrameLayout>
                        <TextView android:id="@+id/tv_ram" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="end" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="42dp" android:layout_height="wrap_content" android:text="Диск" android:textColor="#8993A4" android:textSize="11sp" android:textStyle="bold" />
                        <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:background="@drawable/bar_bg">
                            <View android:id="@+id/bar_disk" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/bar_cpu" />
                        </FrameLayout>
                        <TextView android:id="@+id/tv_disk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="end" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="СЕРВИСЫ" android:textColor="#5A6377" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.14" android:layout_marginBottom="8dp" />
                    <LinearLayout android:id="@+id/services_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="БЕЗОПАСНОСТЬ" android:textColor="#5A6377" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.14" android:layout_marginBottom="8dp" />
                    <LinearLayout android:id="@+id/security_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>

                <Button android:id="@+id/btn_refresh" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="10dp" android:backgroundTint="#2A6D68" android:text="ОБНОВИТЬ" android:textColor="#6EE7DF" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.06" android:insetTop="0dp" android:insetBottom="0dp" />
                <TextView android:id="@+id/tv_updated" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:gravity="center" android:textColor="#5A6377" android:textSize="10sp" />
            </LinearLayout>
        </ScrollView>

        <!-- TAB 2: H2+ -->
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                        <View android:id="@+id/h2_dot" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/pulse_dot" />
                        <TextView android:id="@+id/tv_h2_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:textColor="#00E5A0" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.05" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView android:id="@+id/tv_h2_version" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#5A6377" android:textSize="11sp" android:fontFamily="monospace" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/stat_card_bg" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ВСЕГО" android:textColor="#5A6377" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.1" />
                            <TextView android:id="@+id/tv_h2_total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/stat_card_bg" android:orientation="vertical" android:padding="10dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ОНЛАЙН" android:textColor="#5A6377" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.1" />
                            <TextView android:id="@+id/tv_h2_online" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="#00E5A0" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ПОЛЬЗОВАТЕЛИ" android:textColor="#5A6377" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.14" android:layout_marginBottom="8dp" />
                    <LinearLayout android:id="@+id/users_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ИНФРАСТРУКТУРА" android:textColor="#5A6377" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.14" android:layout_marginBottom="8dp" />
                    <LinearLayout android:id="@+id/infra_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </LinearLayout>

                <Button android:id="@+id/btn_refresh_h2" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="10dp" android:backgroundTint="#2A6D68" android:text="ОБНОВИТЬ" android:textColor="#6EE7DF" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.06" android:insetTop="0dp" android:insetBottom="0dp" />
                <TextView android:id="@+id/tv_updated_h2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:gravity="center" android:textColor="#5A6377" android:textSize="10sp" />
            </LinearLayout>
        </ScrollView>

        <!-- TAB 3: JOURNAL -->
        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/card_bg" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ЖУРНАЛ СОБЫТИЙ" android:textColor="#5A6377" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.14" android:layout_marginBottom="8dp" />
                    <LinearLayout android:id="@+id/log_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                    <TextView android:id="@+id/tv_no_events" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="20dp" android:text="Нет событий — всё работает штатно" android:textColor="#5A6377" android:textSize="12sp" />
                </LinearLayout>

                <Button android:id="@+id/btn_refresh_log" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="10dp" android:backgroundTint="#2A6D68" android:text="ОБНОВИТЬ" android:textColor="#6EE7DF" android:textSize="13sp" android:textStyle="bold" android:letterSpacing="0.06" android:insetTop="0dp" android:insetBottom="0dp" />
                <TextView android:id="@+id/tv_updated_log" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:gravity="center" android:textColor="#5A6377" android:textSize="10sp" />
            </LinearLayout>
        </ScrollView>

    </ViewFlipper>
</LinearLayout>
